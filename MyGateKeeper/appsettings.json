{
  "Services": {
    "AuthZ": {
      "BaseUrl": "http://localhost:5206"
    }
  },
  "Jwt": {
    "Key": "ThisIsSuperSecretKey12345678901234567890",
    "Issuer": "AuthServer",
    "Audience": "MyApps"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "test-route": {
        "ClusterId": "test-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "resource-route": {
        "ClusterId": "resource-cluster",
        "Match": {
          "Path": "/resource/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/resource" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5281/"
          }
        }
      },
      "test-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "resource-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5032/"
          }
        }
      }
    }
  }
}
